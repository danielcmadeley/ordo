---
import Layout from './Layout.astro'

interface Props {
  title: string
  description: string
  date: string
  readTime: string
  category: string
}

const { title, description, date, readTime, category } = Astro.props
---

<Layout title={`${title} | Ordo Blog`} description={description}>
  <div class="blog-page">
    <header class="blog-header">
      <div class="blog-header-inner">
        <nav class="blog-nav">
          <a href="/" class="blog-logo">
            <span class="blog-logo-icon">O</span>
            <span class="blog-logo-text">Ordo</span>
          </a>
          <a href="/blog" class="blog-back">&larr; All posts</a>
        </nav>
      </div>
    </header>

    <main class="blog-main">
      <article class="blog-article">
        <div class="blog-meta">
          <span class="blog-category">{category}</span>
          <span class="blog-sep">&middot;</span>
          <time>{date}</time>
          <span class="blog-sep">&middot;</span>
          <span>{readTime}</span>
        </div>
        <h1 class="blog-title">{title}</h1>
        <p class="blog-excerpt">{description}</p>
        <div class="blog-content">
          <slot />
        </div>
      </article>
    </main>

    <footer class="blog-footer">
      <div class="blog-footer-inner">
        <p>&copy; {new Date().getFullYear()} Ordo. All rights reserved.</p>
      </div>
    </footer>
  </div>
</Layout>

<style>
  .blog-page {
    min-height: 100vh;
    background: var(--background);
    color: var(--foreground);
    font-family: 'Outfit', sans-serif;
  }

  .blog-header {
    border-bottom: 1px solid color-mix(in oklch, var(--border), transparent 60%);
  }

  .blog-header-inner {
    max-width: 48rem;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
  }

  .blog-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .blog-logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    color: inherit;
  }

  .blog-logo-icon {
    display: inline-flex;
    height: 2rem;
    width: 2rem;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    background: var(--foreground);
    color: var(--background);
    font-size: 0.875rem;
    font-weight: 700;
  }

  .blog-logo-text {
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: -0.025em;
  }

  .blog-back {
    font-size: 0.8125rem;
    color: var(--muted-foreground);
    text-decoration: none;
    transition: color 150ms;
  }

  .blog-back:hover {
    color: var(--foreground);
  }

  .blog-main {
    max-width: 48rem;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  .blog-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--muted-foreground);
    margin-bottom: 1.5rem;
  }

  .blog-category {
    background: var(--secondary);
    color: var(--secondary-foreground);
    padding: 0.125rem 0.625rem;
    border-radius: 9999px;
    font-size: 0.6875rem;
    font-weight: 500;
  }

  .blog-sep {
    color: var(--border);
  }

  .blog-title {
    font-size: 2.25rem;
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.15;
    margin: 0 0 1rem;
  }

  .blog-excerpt {
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--muted-foreground);
    margin: 0 0 2.5rem;
    max-width: 36rem;
  }

  .blog-content {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--foreground);
  }

  .blog-content :global(h2) {
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.025em;
    margin: 2.5rem 0 1rem;
  }

  .blog-content :global(h3) {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 2rem 0 0.75rem;
  }

  .blog-content :global(p) {
    margin: 0 0 1.25rem;
    color: var(--muted-foreground);
  }

  .blog-content :global(ul),
  .blog-content :global(ol) {
    margin: 0 0 1.25rem;
    padding-left: 1.5rem;
    color: var(--muted-foreground);
  }

  .blog-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .blog-content :global(blockquote) {
    border-left: 3px solid var(--border);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--muted-foreground);
    font-style: italic;
  }

  .blog-content :global(code) {
    background: var(--muted);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
  }

  .blog-content :global(hr) {
    border: none;
    border-top: 1px solid color-mix(in oklch, var(--border), transparent 60%);
    margin: 2rem 0;
  }

  .blog-footer {
    border-top: 1px solid color-mix(in oklch, var(--border), transparent 60%);
  }

  .blog-footer-inner {
    max-width: 48rem;
    margin: 0 auto;
    padding: 1.5rem;
    font-size: 0.75rem;
    color: var(--muted-foreground);
  }

  @media (max-width: 640px) {
    .blog-title {
      font-size: 1.75rem;
    }

    .blog-excerpt {
      font-size: 1rem;
    }

    .blog-main {
      padding: 2rem 1.5rem 3rem;
    }
  }
</style>
