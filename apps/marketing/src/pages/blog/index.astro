---
import Layout from '../../layouts/Layout.astro'

const posts = [
  {
    slug: 'why-local-first',
    title: 'Why We Chose Local-First Architecture',
    excerpt: 'Most productivity apps treat your data as theirs. We built Ordo so your tasks and notes live on your device first, syncing to the edge only when you choose.',
    date: 'Feb 28, 2026',
    readTime: '6 min read',
    category: 'Engineering',
  },
  {
    slug: 'five-views-one-model',
    title: 'Five Views, One Data Model: How Ordo Keeps Your Projects in Sync',
    excerpt: "List, Kanban, Calendar, Gantt, and Table — every view reads from the same source of truth. Here's how we designed the schema to make that seamless.",
    date: 'Feb 20, 2026',
    readTime: '8 min read',
    category: 'Product',
  },
  {
    slug: 'building-on-cloudflare',
    title: 'Building a Real-Time Sync Engine on Cloudflare Durable Objects',
    excerpt: 'Durable Objects gave us per-user WebSocket sync with zero cold starts. This post walks through our sync architecture and the trade-offs we made.',
    date: 'Feb 12, 2026',
    readTime: '10 min read',
    category: 'Engineering',
  },
  {
    slug: 'daily-journaling-for-builders',
    title: 'Daily Journaling for Builders: Why Reflection Beats Hustle',
    excerpt: "We added a daily journal to Ordo because shipping fast without reflection is just moving in circles. Here's the framework we built around.",
    date: 'Feb 5, 2026',
    readTime: '5 min read',
    category: 'Productivity',
  },
  {
    slug: 'designing-the-knowledge-base',
    title: 'Designing a Knowledge Base That Developers Actually Use',
    excerpt: 'Most note-taking apps are either too simple or too complex. We aimed for the sweet spot — structured notebooks with a fast, block-based editor.',
    date: 'Jan 28, 2026',
    readTime: '7 min read',
    category: 'Design',
  },
]
---

<Layout title="Blog | Ordo" description="Engineering deep-dives, product thinking, and lessons from building Ordo in public.">
  <div class="blog-index">
    <header class="bi-header">
      <div class="bi-header-inner">
        <nav class="bi-nav">
          <a href="/" class="bi-logo">
            <span class="bi-logo-icon">O</span>
            <span class="bi-logo-text">Ordo</span>
          </a>
          <a href="/" class="bi-back">&larr; Home</a>
        </nav>
      </div>
    </header>

    <main class="bi-main">
      <div class="bi-intro">
        <h1 class="bi-title">Blog</h1>
        <p class="bi-subtitle">
          Engineering deep-dives, product thinking, and lessons from building
          Ordo in public.
        </p>
      </div>

      <div class="bi-posts">
        {posts.map((post, i) => (
          <a href={`/blog/${post.slug}`} class:list={['bi-post', { 'bi-post--featured': i === 0 }]}>
            <div class="bi-post-meta">
              <span class="bi-post-category">{post.category}</span>
              <span class="bi-post-dot">&middot;</span>
              <time>{post.date}</time>
              <span class="bi-post-dot">&middot;</span>
              <span>{post.readTime}</span>
            </div>
            <h2 class="bi-post-title">{post.title}</h2>
            <p class="bi-post-excerpt">{post.excerpt}</p>
          </a>
        ))}
      </div>
    </main>

    <footer class="bi-footer">
      <div class="bi-footer-inner">
        <p>&copy; {new Date().getFullYear()} Ordo. All rights reserved.</p>
      </div>
    </footer>
  </div>
</Layout>

<style>
  .blog-index {
    min-height: 100vh;
    background: var(--background);
    color: var(--foreground);
    font-family: 'Outfit', sans-serif;
  }

  .bi-header {
    border-bottom: 1px solid color-mix(in oklch, var(--border), transparent 60%);
  }

  .bi-header-inner {
    max-width: 48rem;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
  }

  .bi-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .bi-logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    color: inherit;
  }

  .bi-logo-icon {
    display: inline-flex;
    height: 2rem;
    width: 2rem;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    background: var(--foreground);
    color: var(--background);
    font-size: 0.875rem;
    font-weight: 700;
  }

  .bi-logo-text {
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: -0.025em;
  }

  .bi-back {
    font-size: 0.8125rem;
    color: var(--muted-foreground);
    text-decoration: none;
    transition: color 150ms;
  }

  .bi-back:hover {
    color: var(--foreground);
  }

  .bi-main {
    max-width: 48rem;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  .bi-intro {
    margin-bottom: 3rem;
  }

  .bi-title {
    font-size: 2.5rem;
    font-weight: 600;
    letter-spacing: -0.025em;
    margin: 0 0 0.75rem;
  }

  .bi-subtitle {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--muted-foreground);
    margin: 0;
    max-width: 32rem;
  }

  .bi-posts {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .bi-post {
    display: block;
    padding: 1.25rem 1.5rem;
    border: 1px solid color-mix(in oklch, var(--border), transparent 40%);
    border-radius: 0.75rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 150ms;
  }

  .bi-post:hover {
    border-color: var(--border);
  }

  .bi-post--featured {
    padding: 1.5rem 2rem;
  }

  .bi-post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--muted-foreground);
    margin-bottom: 0.625rem;
  }

  .bi-post-category {
    background: var(--secondary);
    color: var(--secondary-foreground);
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    font-size: 0.6875rem;
    font-weight: 500;
  }

  .bi-post-dot {
    color: var(--border);
  }

  .bi-post-title {
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.3;
    margin: 0 0 0.375rem;
  }

  .bi-post--featured .bi-post-title {
    font-size: 1.5rem;
  }

  .bi-post-excerpt {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--muted-foreground);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .bi-post--featured .bi-post-excerpt {
    -webkit-line-clamp: 3;
  }

  .bi-footer {
    border-top: 1px solid color-mix(in oklch, var(--border), transparent 60%);
  }

  .bi-footer-inner {
    max-width: 48rem;
    margin: 0 auto;
    padding: 1.5rem;
    font-size: 0.75rem;
    color: var(--muted-foreground);
  }

  @media (max-width: 640px) {
    .bi-title {
      font-size: 1.75rem;
    }

    .bi-main {
      padding: 2rem 1.5rem 3rem;
    }

    .bi-post--featured {
      padding: 1.25rem 1.5rem;
    }

    .bi-post--featured .bi-post-title {
      font-size: 1.25rem;
    }
  }
</style>
