{
  "name": "@ordo/api",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 3001",
    "dev:pwa": "wrangler dev --port 3001",
    "build": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "typecheck": "tsc --noEmit",
    "db:generate": "cd ../.. && ./apps/api/node_modules/.bin/drizzle-kit generate",
    "db:migrate": "cd ../.. && ./apps/api/node_modules/.bin/drizzle-kit migrate"
  },
  "dependencies": {
    "@livestore/sync-cf": "0.4.0-dev.14",
    "@ordo/shared": "workspace:*",
    "@orpc/openapi": "^1.13.5",
    "@orpc/server": "^1.13.5",
    "@orpc/zod": "^1.13.5",
    "@types/node": "^25.3.0",
    "ai": "^6.0.105",
    "better-auth": "^1.3.34",
    "better-auth-cloudflare": "^0.2.8",
    "drizzle-orm": "^0.44.7",
    "hono": "^4.12.2",
    "workers-ai-provider": "^3.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250214.0",
    "drizzle-kit": "^0.31.7",
    "typescript": "^5.7.2",
    "wrangler": "^4.40.3"
  }
}
