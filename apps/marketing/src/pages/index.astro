---
import Layout from '../layouts/Layout.astro'

const appUrl = 'https://app.getordo.co'
---

<Layout title="Ordo | Focus on what matters" description="Ordo is a focused task manager that keeps your day moving.">
	<main class="page">
		<section class="hero">
			<p class="eyebrow">Ordo</p>
			<h1>Task management that actually keeps momentum.</h1>
			<p class="subtitle">
				Capture tasks fast, prioritize the right work, and stay in flow across devices.
			</p>
			<div class="actions">
				<a class="primary" href={appUrl}>Open the app</a>
				<a class="secondary" href={appUrl}>Go to app.getordo.co</a>
			</div>
		</section>
	</main>
</Layout>

<style>
	:global(body) {
		font-family: Outfit, Avenir Next, Segoe UI, sans-serif;
		background:
			radial-gradient(circle at 12% 10%, rgba(80, 126, 255, 0.15), transparent 42%),
			radial-gradient(circle at 88% 18%, rgba(21, 187, 140, 0.14), transparent 45%),
			linear-gradient(180deg, #f4f7fc 0%, #eef2f7 100%);
		color: #152033;
	}

	.page {
		min-height: 100vh;
		display: grid;
		place-items: center;
		padding: 2rem;
	}

	.hero {
		max-width: 42rem;
		text-align: center;
		padding: 2.25rem;
		border: 1px solid rgba(21, 32, 51, 0.1);
		border-radius: 1.25rem;
		background: rgba(255, 255, 255, 0.88);
		box-shadow: 0 24px 60px rgba(16, 25, 40, 0.08);
	}

	.eyebrow {
		margin: 0;
		font-size: 0.82rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		font-weight: 700;
		color: #2b5fb5;
	}

	h1 {
		margin: 0.5rem 0 1rem;
		font-size: clamp(2rem, 5vw, 3rem);
		line-height: 1.1;
	}

	.subtitle {
		margin: 0 auto;
		max-width: 34rem;
		font-size: 1.05rem;
		line-height: 1.6;
		color: #3f4f69;
	}

	.actions {
		margin-top: 1.75rem;
		display: flex;
		justify-content: center;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.68rem 1.1rem;
		border-radius: 0.72rem;
		font-weight: 600;
		text-decoration: none;
		transition: transform 120ms ease, box-shadow 120ms ease, background-color 120ms ease;
	}

	a:hover {
		transform: translateY(-1px);
	}

	.primary {
		background: #1e62d0;
		color: #fff;
		box-shadow: 0 10px 24px rgba(30, 98, 208, 0.25);
	}

	.primary:hover {
		background: #1553b8;
	}

	.secondary {
		border: 1px solid #c5d0e2;
		background: #fff;
		color: #2d405f;
	}

	@media (max-width: 640px) {
		.hero {
			padding: 1.5rem;
		}

		a {
			width: 100%;
		}
	}
</style>
