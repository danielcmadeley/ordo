{
  "name": "livestore-todo-auth-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.17",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:pwa": "turbo run dev:pwa",
    "dev:web": "turbo run dev --filter=@repo/web",
    "dev:api": "turbo run dev --filter=@repo/api",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "deploy:api": "turbo run deploy --filter=@repo/api",
    "db:generate": "turbo run db:generate --filter=@repo/api",
    "db:migrate": "turbo run db:migrate --filter=@repo/api"
  },
  "devDependencies": {
    "dotenv": "^17.3.1",
    "turbo": "^2.5.8",
    "typescript": "^5.7.2"
  }
}
